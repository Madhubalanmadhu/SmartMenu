# Local development can use SQLite. Production should use PostgreSQL.
# Examples:
# DATABASE_URL=sqlite:///restaurant.db
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=sqlite:///restaurant.db
SECRET_KEY=change-me
DEBUG=False

# Firebase Admin service account values from Firebase Console.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=

# Weather provider. Use openweathermap with OPENWEATHER_API_KEY, or weatherapi with WEATHERAPI_KEY.
WEATHER_PROVIDER=openweathermap
OPENWEATHER_API_KEY=
WEATHERAPI_KEY=

# Optional Gemini assistant settings.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
